// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  staff
  dean
  admin
}

enum LeaveStatus {
  pending_dean
  approved
  rejected
}

enum HalfDayType {
  first_half
  second_half
}

enum NotificationType {
  leave_applied
  dean_approved
  final_decision
}

model User {
  id          Int            @id @default(autoincrement())
  name        String
  email       String         @unique
  password    String
  mustChangePassword Boolean  @default(true)
  designation String
  role        UserRole       @default(staff)
  createdAt   DateTime       @default(now())

  leaves           Leave[]        @relation("LeaveApplicant")
  deanReviewLeaves Leave[]        @relation("LeaveDean")
  leaveBalances    LeaveBalance[]
  notifications    Notification[]
}

model LeaveYear {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean       @default(false)
  monthlyLimit Float         @default(2.5)
  yearlyLimit  Float         @default(30)
  createdAt    DateTime      @default(now())

  leaves       Leave[]
  leaveBalances LeaveBalance[]

  @@index([isActive])
}

model Leave {
  id              Int         @id @default(autoincrement())
  userId          Int
  yearId          Int
  deanId          Int?
  fromDate        DateTime
  toDate          DateTime
  isHalfDay       Boolean     @default(false)
  halfDayType     HalfDayType?
  totalDays       Float
  reason          String
  attachment      String?
  status          LeaveStatus @default(pending_dean)
  deanApproved    Boolean     @default(false)
  rejectionReason String?
  createdAt       DateTime    @default(now())

  user          User           @relation("LeaveApplicant", fields: [userId], references: [id])
  leaveYear     LeaveYear      @relation(fields: [yearId], references: [id])
  dean          User?          @relation("LeaveDean", fields: [deanId], references: [id])
  notifications Notification[]

  @@index([userId])
  @@index([yearId])
  @@index([status])
  @@index([fromDate, toDate])
}

model LeaveBalance {
  id        Int      @id @default(autoincrement())
  userId    Int
  yearId    Int
  year      Int
  total     Float    @default(30)
  used      Float    @default(0)
  remaining Float    @default(30)
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  leaveYear LeaveYear @relation(fields: [yearId], references: [id])

  @@unique([userId, yearId])
  @@index([yearId])
  @@index([year])
}

model Holiday {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime @unique
  createdAt DateTime @default(now())
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  leaveId   Int?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id])
  leave Leave? @relation(fields: [leaveId], references: [id])

  @@index([userId, isRead])
}
