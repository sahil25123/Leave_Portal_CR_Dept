# Frontend build/runtime
VITE_API_BASE_URL=/api

# Public URLs used by the application and emails
FRONTEND_URL=https://iitd.example.edu/leave-portal
BACKEND_URL=https://iitd.example.edu/api
FRONTEND_ORIGIN=https://iitd.example.edu
CORS_ORIGIN=https://iitd.example.edu

# Backend runtime
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=mysql://leave_portal_user:replace-with-a-password@mysql:3306/leave_portal

# MySQL
MYSQL_DATABASE=leave_portal
MYSQL_USER=leave_portal_user
MYSQL_PASSWORD=replace-with-a-password
MYSQL_ROOT_PASSWORD=replace-with-a-root-password

# Optional integrations
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
COMPANY_LOGO_URL=
CALENDARIFIC_API_KEY=